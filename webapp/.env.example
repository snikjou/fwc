# Cosmos DB connection settings
COSMOS_ENDPOINT=https://agreementscosmosdb2.documents.azure.com:443/
COSMOS_DATABASE=contracts
COSMOS_CONTAINER=agreementMetadata

# Preferred local dev option: full connection string
# COSMOS_CONNECTION_STRING=AccountEndpoint=https://agreementscosmosdb2.documents.azure.com:443/;AccountKey=<key>;
COSMOS_CONNECTION_STRING=

# Alternative local dev option: endpoint + key
COSMOS_KEY=

# Optional: Azure AD auth (only set true if credentials are configured)
COSMOS_USE_AAD=false

PORT=3000
